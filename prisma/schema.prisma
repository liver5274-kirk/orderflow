generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  createdAt DateTime  @default(now())
  orders    Order[]
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  phone     String    @default("")
  email     String    @default("")
  address   String    @default("")
  notes     String    @default("")
  createdAt DateTime  @default(now())
  orders    Order[]
}

model Order {
  id        String    @id @default(cuid())
  orderNo   String    @unique
  amount    Float
  status    String    @default("pending")
  orderDate DateTime  @default(now())
  notes     String    @default("")
  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  createdBy  String
  user       User     @relation(fields: [createdBy], references: [id])
}

// ── BOM & Inventory ──

model Supplier {
  id            String           @id @default(cuid())
  name          String
  contactPerson String           @default("")
  phone         String           @default("")
  email         String           @default("")
  address       String           @default("")
  taxId         String           @default("")
  paymentTerms  String           @default("月結30天")
  notes         String           @default("")
  createdAt     DateTime         @default(now())

  materials       Material[]
  purchaseOrders  PurchaseOrder[]
}

model Material {
  id           String             @id @default(cuid())
  name         String
  category     String             @default("原料")
  unit         String             @default("個")
  currentStock Float              @default(0)
  minStock     Float              @default(10)
  unitCost     Float              @default(0)
  notes        String             @default("")
  createdAt    DateTime           @default(now())

  supplierId   String?
  supplier     Supplier?          @relation(fields: [supplierId], references: [id])

  bomItems         BOMItem[]
  transactions     StockTransaction[]
  purchaseItems    PurchaseOrderItem[]
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  orderNo      String              @unique
  supplierId   String
  status       String              @default("待確認")
  totalAmount  Float               @default(0)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  notes        String              @default("")
  createdAt    DateTime            @default(now())

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  items     PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  materialId      String
  quantity        Float
  unitPrice       Float
  subtotal        Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  material      Material      @relation(fields: [materialId], references: [id])

  @@unique([purchaseOrderId, materialId])
}

model Product {
  id          String    @id @default(cuid())
  name        String
  description String    @default("")
  price       Float     @default(0)
  createdAt   DateTime  @default(now())

  bomItems    BOMItem[]
}

model BOMItem {
  id         String  @id @default(cuid())
  productId  String
  materialId String
  quantity   Float

  product  Product  @relation(fields: [productId], references: [id])
  material Material @relation(fields: [materialId], references: [id])

  @@unique([productId, materialId])
}

model StockTransaction {
  id         String   @id @default(cuid())
  materialId String
  type       String
  quantity   Float
  beforeStock Float
  afterStock Float
  reason     String   @default("")
  orderNo    String   @default("")
  createdAt  DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id])
}
